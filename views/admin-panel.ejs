<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <% if (pendingItems && pendingItems.length > 0 ){%>
        <% pendingItems.forEach((item) => { %>
            <div>
            <h1><%= item.title%></h1>   
            <button type="submit" onclick="approveItem(<%= item.id%>)" id="button<%= item.id%>">Approve</button>
            <button type="submit" onclick="disapproveItem(<%= item.id%>)" id="button<%= item.id%>">Disapprove</button> 
            </div>
            <%})%>
    <%}else{%>
        <h1>Немає оголошень, які очікують на апрув</h1>
    <%}%>

    <form action="/category" method="post">
        <label>
            <input type="text" placeholder="Назва категорії" name="name">
        </label>
        <button type="submit">Додати</button>
    </form>
    <script>
    async function approveItem(id) {
        const btn = document.getElementById(`button${id}`);
        
        btn.disabled = true;
        btn.innerText = "Processing...";

        try {
            const response = await fetch(`/admin/panel/${id}/approve`, {
                method: 'PATCH'
            });

            if (response.ok) {
                btn.parentElement.remove(); 
                console.log(`Item ${id} approved!`);
            } else {
                alert("Помилка при апруві");
                btn.disabled = false;
                btn.innerText = "Approve";
            }
        } catch (err) {
            console.error("Мережева помилка:", err);
            btn.disabled = false;
            btn.innerText = "Approve";
        }
    }
    async function disapproveItem(id) {
        const btn = document.getElementById(`button${id}`);
        btn.disabled = true
        btn.innerText = "Processing..."

        try{
            const response = await fetch(`/admin/panel/${id}/disapprove`, {
                method: "PATCH"
            })

            if (response.ok){
                btn.parentElement.remove();
                console.log(`Item ${id} disapproved!`);
            }else{
                alert("Помилка під час дізапруву")
                btn.disabled = false;
                btn.innerText = "Disapprove"
            }
        }catch(err){
            console.error("Мережева помилка:", err);
            btn.disabled = false;
            btn.innerText = "Disapprove";
        }
        
    }
</script>
</body>
</html>